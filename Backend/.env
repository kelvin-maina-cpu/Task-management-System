# Server Configuration
PORT=5000

# MongoDB Connection String
# Replace with your actual MongoDB connection string
# Example: mongodb://localhost:27017/task-management
MONGO_URI=mongodb://localhost:27017/task-management

# JWT Secrets (IMPORTANT: Change these to secure random strings in production!)
# JWT_ACCESS_SECRET must be at least 32 characters
JWT_ACCESS_SECRET=your_access_secret_key_here_min_32_chars_long
JWT_REFRESH_SECRET=your_refresh_secret_key_here_different_min_32

# Token Expiry (Optional)
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Node Environment
NODE_ENV=development

