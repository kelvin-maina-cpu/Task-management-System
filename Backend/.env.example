# Backend Environment Configuration
# Copy this to .env and fill in your actual values

# Environment
NODE_ENV=development

# Server
PORT=5000

# Database
# MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/task-management?retryWrites=true&w=majority
# Local MongoDB: mongodb://localhost:27017/task-management
MONGO_URI=mongodb://localhost:27017/task-management

# JWT Secrets (Generate with: openssl rand -base64 32)
# Must be at least 32 characters!
JWT_ACCESS_SECRET=your-super-secret-jwt-access-key-must-be-at-least-32-chars-long-MIN!
JWT_REFRESH_SECRET=your-super-secret-jwt-refresh-key-must-be-at-least-32-chars-long-!MIN

# Optional: CORS origins (comma-separated for production)
# CORS_ORIGINS=https://example.com,https://app.example.com

# Optional: API documentation
# API_DOCS_ENABLED=true

# Optional: Email settings (for future notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
