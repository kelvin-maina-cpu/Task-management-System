# Test environment variables
# Create a separate test MongoDB database (e.g., local mongod --dbpath ./test-data or MongoDB Atlas test cluster)

TEST_DB_URI=mongodb://localhost:27017/taskmanagement_test
MONGO_URI=mongodb://localhost:27017/taskmanagement_test  # fallback

# JWT secrets for test (generate your own)
JWT_ACCESS_SECRET=your-super-secret-jwt-access-key-for-tests
JWT_REFRESH_SECRET=your-super-secret-jwt-refresh-key-for-tests

# Other prod vars from .env not needed for test or override
NODE_ENV=test
PORT=5001
