# Frontend Environment Configuration - Development
# Used when running `npm run dev` locally

# API Configuration
# Leave empty to use Vite proxy (see vite.config.ts)
# The proxy automatically routes /api requests to http://localhost:5000/dev
VITE_API_URL=/api
VITE_BACKEND_URL=http://localhost:5000

# Optional: Feature flags
# VITE_ENABLE_ANALYTICS=false
# VITE_ENABLE_DEVTOOLS=true
